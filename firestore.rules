rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.email.matches('bailleur_.*') ||
        exists(/databases/$(database)/documents/inquilinos/$(request.auth.uid)) == false
      );
    }

    function isInquilino(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isSelf() {
      return isAuth() && request.auth.uid == resource.data.inquilinoId;
    }

    function isSelfOrAdmin() {
      return isSelf() || isAdmin();
    }

    // Inquilinos
    match /inquilinos/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Habitaciones
    match /habitaciones/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Pagos
    match /pagos/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Tickets
    match /tickets/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isSelfOrAdmin();
    }

    // Visitas
    match /visitas/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isSelfOrAdmin();
    }

    // Turnos limpieza
    match /turnos_limpieza/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Permutas limpieza
    match /permutas_limpieza/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // Reportes limpieza
    match /reportes_limpieza/{id} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    // Lavanderia
    match /lavanderia/{id} {
      allow read: if isSelfOrAdmin();
      allow write: if isAuth();
    }

    // Reservas lavanderia
    match /reservas_lavanderia/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isSelfOrAdmin();
    }

    // Almacenamiento
    match /almacenamiento/{id} {
      allow read: if isSelfOrAdmin();
      allow write: if isAdmin();
    }

    // Espacios almacenamiento
    match /espacios_almacenamiento/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Huespedes extra
    match /huespedes_extra/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isSelfOrAdmin();
    }

    // Noticias
    match /noticias/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuth();
      allow write: if isAdmin();

      match /mensajes/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
      }
    }

    // Sesiones
    match /sesiones/{id} {
      allow read: if isAuth() && (resource.data.usuarioId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.usuarioId == request.auth.uid || isAdmin());
    }

    // Alertas seguridad
    match /alertas_seguridad/{id} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // Expedientes
    match /expedientes/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Documentos de expediente (subcoleccion)
    match /inquilinos/{uid}/documentos/{docId} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    // Facturas
    match /facturas/{id} {
      allow read: if isSelfOrAdmin();
      allow write: if isAdmin();
    }

    // Solicitudes factura
    match /solicitudes_factura/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Cupones
    match /cupones/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Cupones usos
    match /cupones_usos/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth();
    }

    // Configuracion
    match /configuracion/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Scores
    match /scores/{id} {
      allow read: if isAuth() && (resource.data.inquilinoId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Restricciones
    match /restricciones/{id} {
      allow read: if isSelfOrAdmin();
      allow write: if isAdmin();
    }

    // Apelaciones
    match /apelaciones/{id} {
      allow read: if isSelfOrAdmin();
      allow create: if isAuth() && request.resource.data.inquilinoId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Gastos
    match /gastos/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Documentos plantillas
    match /documentosPlantillas/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
